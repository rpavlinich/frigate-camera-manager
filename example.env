# frigate-camera-manager — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# ── Frigate API ──────────────────────────────────────────────────────────
FRIGATE_API_BASE=http://frigate.home:5000
FRIGATE_API_TOKEN=

# Basic auth (only needed if NOT using token auth)
FRIGATE_API_USERNAME=
FRIGATE_API_PASSWORD=

# ── Discord Webhooks ─────────────────────────────────────────────────────
# Default webhook — used when no per-camera webhook is registered
DISCORD_DEFAULT_WEBHOOK_URL=

# Per-camera webhooks (optional — uncomment and fill as needed)
# DISCORD_WEBHOOK_FRONT_YARD=
# DISCORD_WEBHOOK_BACK_YARD=
# DISCORD_WEBHOOK_DRIVEWAY=
# DISCORD_WEBHOOK_GARAGE=
